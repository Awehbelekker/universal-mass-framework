# Copy this file to .env and fill in the values for local development.
# Never commit .env to version control.

# ── Runtime ──────────────────────────────────────────────────────────────────
MASS_ENV=development

# API key for /search endpoint — leave empty to disable auth locally
MASS_API_KEY=

# ── GCP (only needed when running Cloud Build locally) ───────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1

# ── LLM via LiteLLM — swap the model without touching code ───────────────────
LITELLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Provide whichever LLM provider key(s) you use:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Supabase — vector store for pgvector retrieval ───────────────────────────
# Leave empty to run with the stub retrieve_node (safe for CI / local dev)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Web Search Agent (Move 4) ─────────────────────────────────────────────────
# Provide at least one key to enable live web search; Brave is tried first.
BRAVE_API_KEY=
SERPER_API_KEY=

# ── Langfuse observability ────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

