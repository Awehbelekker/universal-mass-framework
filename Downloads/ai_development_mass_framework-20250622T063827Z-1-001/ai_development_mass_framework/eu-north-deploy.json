{
  "InstanceIds": ["i-0a612349ea6cde3d2"],
  "DocumentName": "AWS-RunShellScript",
  "Parameters": {
    "commands": [
      "echo '=== MASS Framework Deployment - EU North ==='",
      "date",
      "sudo pkill -f python 2>/dev/null || true",
      "sleep 2",
      "cat > /tmp/mass_server.py << 'EOF'",
      "from http.server import HTTPServer, BaseHTTPRequestHandler",
      "import json, datetime",
      "class MassHandler(BaseHTTPRequestHandler):",
      "    def do_GET(self):",
      "        self.send_response(200)",
      "        self.send_header('Access-Control-Allow-Origin', '*')",
      "        if self.path == '/':",
      "            self.send_header('Content-type', 'text/html')",
      "            self.end_headers()",
      "            html = '''<html><head><title>MASS Framework LIVE</title><style>body{font-family:Arial;background:#667eea;color:white;text-align:center;padding:50px}h1{font-size:3rem}.btn{padding:12px 24px;background:#4CAF50;color:white;text-decoration:none;border-radius:25px;margin:10px}</style></head><body><h1>MASS Framework</h1><h2>LIVE & READY!</h2><p>Multi-Agent AI Development System</p><p>Region: EU-North-1 | Production Ready</p><div><a href=\"/health\" class=\"btn\">Health Check</a><a href=\"/api\" class=\"btn\">API Test</a></div></body></html>'''",
      "            self.wfile.write(html.encode('utf-8'))",
      "        elif self.path == '/health':",
      "            self.send_header('Content-type', 'application/json')",
      "            self.end_headers()",
      "            health = {'status': 'healthy', 'service': 'MASS Framework', 'version': '1.0.0', 'timestamp': datetime.datetime.now().isoformat(), 'region': 'eu-north-1'}",
      "            self.wfile.write(json.dumps(health, indent=2).encode('utf-8'))",
      "        elif self.path.startswith('/api'):",
      "            self.send_header('Content-type', 'application/json')",
      "            self.end_headers()",
      "            api = {'message': 'MASS Framework API is running', 'endpoint': self.path, 'timestamp': datetime.datetime.now().isoformat(), 'region': 'eu-north-1'}",
      "            self.wfile.write(json.dumps(api, indent=2).encode('utf-8'))",
      "        else:",
      "            self.send_header('Content-type', 'application/json')",
      "            self.end_headers()",
      "            error = {'error': 'Endpoint not found', 'path': self.path}",
      "            self.wfile.write(json.dumps(error, indent=2).encode('utf-8'))",
      "",
      "if __name__ == '__main__':",
      "    HOST = '0.0.0.0'",
      "    PORT = 8000",
      "    print('Starting MASS Framework on {}:{}'.format(HOST, PORT))",
      "    server = HTTPServer((HOST, PORT), MassHandler)",
      "    server.serve_forever()",
      "EOF",
      "echo 'Starting MASS Framework server...'",
      "nohup python3 /tmp/mass_server.py > /tmp/mass_server.log 2>&1 &",
      "sleep 5",
      "curl -s http://localhost:8000/health",
      "echo 'MASS Framework deployment completed!'"
    ]
  }
}
