# PROMETHEUS MCP Server Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CLUSTER_MODE=false

# PROMETHEUS API Configuration
PROMETHEUS_API_BASE_URL=https://api.prometheus-trading.com
PROMETHEUS_API_KEY=your-api-key-here
PROMETHEUS_API_VERSION=v1

# OAuth2 Configuration
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
OAUTH_AUTHORIZATION_URL=https://api.prometheus-trading.com/oauth/authorize
OAUTH_TOKEN_URL=https://api.prometheus-trading.com/oauth/token

# JWT Configuration
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_MAX_ORDERS_PER_MIN=10
RATE_LIMIT_MAX_ORDERS_PER_DAY=100

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/prometheus-mcp.log

# WebSocket Configuration
WS_PORT=3001
WS_HEARTBEAT_INTERVAL=30000

# Cache Configuration
CACHE_TTL_QUOTES=5000
CACHE_TTL_PORTFOLIO=30000
CACHE_TTL_MARKET_DATA=10000

# Neural Forge Configuration
NEURAL_FORGE_ENDPOINT=https://neural-forge.prometheus-trading.com
NEURAL_FORGE_API_KEY=your-neural-forge-api-key

# Security Configuration
CORS_ORIGIN=*
CORS_CREDENTIALS=true
HELMET_ENABLED=true

# Monitoring Configuration
METRICS_ENABLED=true
METRICS_PORT=3002
HEALTH_CHECK_INTERVAL=30000

# Development Configuration
DEBUG=prometheus:*
VERBOSE_LOGGING=true
