# MASS Framework Environment Configuration
# Copy this file to .env and fill in your actual values

# Core Configuration
JWT_SECRET=your-jwt-secret-key-here
DATABASE_URL=sqlite:///mass_framework.db
REDIS_URL=redis://localhost:6379

# Social Authentication Providers
# Configure the providers you want to enable

# Google OAuth2 Configuration
# Setup URL: https://console.developers.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Facebook OAuth2 Configuration
# Setup URL: https://developers.facebook.com/
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
FACEBOOK_REDIRECT_URI=http://localhost:8000/auth/facebook/callback

# GitHub OAuth2 Configuration
# Setup URL: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# Microsoft OAuth2 Configuration
# Setup URL: https://portal.azure.com/
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback

# LinkedIn OAuth2 Configuration
# Setup URL: https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/linkedin/callback

# Twitter OAuth2 Configuration
# Setup URL: https://developer.twitter.com/
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
TWITTER_REDIRECT_URI=http://localhost:8000/auth/twitter/callback

# Optional Configuration
DEBUG=true
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
