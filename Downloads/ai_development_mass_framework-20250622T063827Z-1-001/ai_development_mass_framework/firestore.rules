rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Check if user is in the allowlist
    function isAllowedUser() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/allowed_users/$(request.auth.token.email));
    }
    
    // Check if user is admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/allowed_users/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/allowed_users/$(request.auth.token.email)).data.role == 'admin';
    }
    
    // Allowed users collection - admin only write, self read
    match /allowed_users/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if isAdmin();
    }
    
    // Access requests - anyone can create, admin can read/update
    match /access_requests/{requestId} {
      allow create: if true; // Anyone can request access
      allow read, update: if isAdmin();
    }
    
    // Registrations - anyone can create, admin can read/update
    match /registrations/{registrationId} {
      allow create: if true; // Anyone can register
      allow read, update: if isAdmin();
    }
    
    // Users can read/write their own data (if allowed)
    match /users/{userId} {
      allow read, write: if isAllowedUser() && request.auth.uid == userId;
    }
    
    // All allowed users can read agents
    match /agents/{agentId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser() && 
        (resource == null || resource.data.owner == request.auth.uid);
    }
    
    // Workflows - allowed users can manage their own
    match /workflows/{workflowId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser() && 
        (resource == null || resource.data.owner == request.auth.uid);
    }
    
    // Chat sessions - allowed users can access their own
    match /chat_sessions/{sessionId} {
      allow read, write: if isAllowedUser() && 
        (resource == null || resource.data.participants[request.auth.uid] != null);
    }
    
    // Analytics - admin only write, allowed users can read
    match /analytics/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAdmin();
    }
    
    // Trading data - allowed users only
    match /trading/{docId} {
      allow read, write: if isAllowedUser();
    }
    
    // Market data - allowed users only
    match /market_data/{docId} {
      allow read: if isAllowedUser();
      allow write: if isAdmin();
    }
  }
}
